{
  "name": "stay-connected",
  "version": "1.0.0",
  "private": true,
  "description": "Kumbh Mela Group Tracking App - Never lose your group",
  "scripts": {
    "dev": "pnpm --parallel --filter ./packages/* dev",
    "dev:server": "pnpm --filter @stay-connected/server dev",
    "dev:client": "pnpm --filter @stay-connected/client dev",
    "build": "pnpm --filter @stay-connected/shared build && pnpm --parallel --filter ./packages/{server,client} build",
    "build:shared": "pnpm --filter @stay-connected/shared build",
    "build:server": "pnpm --filter @stay-connected/server build",
    "build:client": "pnpm --filter @stay-connected/client build",
    "lint": "pnpm --parallel --filter ./packages/* lint",
    "clean": "pnpm --parallel --filter ./packages/* clean"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "dependencies": {
    "react-native-maps": "^1.27.2"
  }
}
